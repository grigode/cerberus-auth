# ===========================
# APP CONFIGURATION
# ===========================

# Name of your application
APP_NAME=Your App Name

# Port number where the server will run
PORT=8000

# Enables or disables the Content Security Policy (Helmet)
# Set to "true" to enable CSP headers, "false" to disable
CONTENT_SECURITY_POLICY=false

# ===========================
# SEED DATABASE
# ===========================

# Change this in production
SUPERADMIN_USERNAME=admin
SUPERADMIN_PROFILE_FIRSTNAME=Super
SUPERADMIN_PROFILE_LASTNAME=Admin
SUPERADMIN_EMAIL=admin@system.local
SUPERADMIN_PASSWORD=ChangeMe123!

# ===========================
# SECURITY KEYS
# ===========================

# Secret key used to sign cookies (keep it private)
COOKIE_KEY=cookie-key


# ===========================
# CORS CONFIGURATION
# ===========================

# Allowed origins for cross-origin requests
CORS_ORIGINS=http://localhost:3000

# Whether or not to allow credentials (cookies, headers, etc.)
CORS_CREDENTIALS=true

# HTTP methods allowed for CORS
CORS_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS


# ===========================
# DATABASE CONFIG
# ===========================

MAIN_DATABASE_HOST=localhost
MAIN_DATABASE_PORT=3306
MAIN_DATABASE_USERNAME=root
MAIN_DATABASE_PASSWORD=<password>
MAIN_DATABASE_DATABASE=cerberus_auth
MAIN_DATABASE_SYNCHRONIZE=1
MAIN_DATABASE_TIMEZONE=+00:00
